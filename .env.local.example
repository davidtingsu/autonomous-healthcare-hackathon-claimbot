NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Drizzle ORM — Supabase direct Postgres connection (Settings → Database → Connection string)
# Also used by the LangGraph PostgresSaver checkpointer (HITL interrupt state).
# NOTE: the checkpointer uses node-postgres with named prepared statements, which
# can break against Supabase's transaction pooler (PgBouncer, port 6543). If
# checkpointer setup()/queries error, switch DATABASE_URL to the session pooler
# (port 5432) or a direct connection.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Vercel AI SDK providers
LLM_PROVIDER=openai
OPENAI_API_KEY=
XAI_API_KEY=

# Optional: Vercel AI Gateway
# AI_GATEWAY_API_KEY=
